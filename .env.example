# --- Reddit API Configuration ---
# Create an app describing yourself as a script at: https://www.reddit.com/prefs/apps
# Type: script
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT="CalcPandaPublisher/1.0 by your_username"
# Target Subreddit (defaults to your profile u_username if empty, or set to 'test')
REDDIT_SUBREDDIT=test

# --- Medium API Configuration ---
# Get token from: https://medium.com/me/settings/security-apps -> Integration tokens
MEDIUM_INTEGRATION_TOKEN=your_medium_token_here
# Optional (script will auto-fetch if missing)
MEDIUM_AUTHOR_ID=
